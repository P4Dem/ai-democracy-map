---
import "@/styles/globals.css";
import { ThreatMap } from "@/components/ThreatMap";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Threats, Mitigation Strategies and Opportunities for Democracy in the Face of AI</title>
    <meta
      name="description"
      content="Explore how AI intersects with democratic institutions — threats, mitigation strategies, and opportunities mapped to the IDEA Democracy Assessment Framework."
    />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / social preview -->
    <meta property="og:title" content="Threats, Mitigation Strategies and Opportunities for Democracy in the Face of AI" />
    <meta property="og:description" content="Explore how AI intersects with democratic institutions — threats, mitigation strategies, and opportunities mapped to the IDEA Democracy Assessment Framework." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Font preloads (prevent Beatrice flash) -->
    <link rel="preload" href="/fonts/Beatrice-Regular.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/Beatrice-Bold.otf" as="font" type="font/otf" crossorigin />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <main>
      <ThreatMap client:load />
    </main>
  </body>
</html>
